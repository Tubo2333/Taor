{
  "name": "taor",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "Taor — TypeScript Agent Orchestration Runtime. 12 packages, AsyncGenerator-based TAOR loop, 4-tier permission engine, sub-agent process isolation.",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "demo": "npx tsx examples/demo.ts",
    "lint": "eslint packages/ --ext .ts"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-otlp-grpc": "^0.26.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "claude",
    "gpt",
    "typescript",
    "taor",
    "agent-runtime",
    "multi-agent",
    "permission-engine"
  ],
  "author": "Zuo Xin (Tubo2333)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tubo2333/taor"
  }
}
